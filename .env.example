# ============================================================
# Snowflake Excel Add-in — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
# Port the Express server listens on (default: 3000)
PORT=3000

# Set to "true" to enable HTTPS for local development.
# Requires cert.pem and key.pem in server/ (run: npm run setup-certs)
HTTPS=true

# --- OAuth (required for production / SPCS deployment) ---

# The OAuth Client ID issued by Snowflake after creating the SECURITY INTEGRATION.
# Retrieve with: SELECT SYSTEM$SHOW_OAUTH_CLIENT_SECRETS('SNOWFLAKE_EXCEL_ADDIN');
OAUTH_CLIENT_ID=

# The full callback URL registered in your Snowflake SECURITY INTEGRATION.
# Local dev:   https://localhost:3000/oauth/callback
# SPCS prod:   https://<hash>-<account>.snowflakecomputing.app/oauth/callback
OAUTH_REDIRECT_URI=https://localhost:3000/oauth/callback
